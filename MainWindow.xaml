<Window x:Class="HyperionWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hyperion" Height="880" Width="1200"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="hyperion.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.Row="0" Background="#252526">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                <Image Source="hyperion.ico" Width="16" Height="16" Margin="0,0,8,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="Hyperion" Foreground="#999999" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>

            
            <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinBtn" Content="&#xE921;" Click="MinBtn_Click"
                        Style="{StaticResource TitleBarBtnStyle}"/>
                <Button x:Name="MaxBtn" Content="&#xE922;" Click="MaxBtn_Click"
                        Style="{StaticResource TitleBarBtnStyle}"/>
                <Button x:Name="CloseBtn" Content="&#xE8BB;" Click="CloseBtn_Click"
                        Style="{StaticResource TitleBarCloseBtnStyle}"/>
            </StackPanel>
        </Grid>

        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            
            <Border Grid.Column="0" Background="{StaticResource NavBgBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    
                    <StackPanel DockPanel.Dock="Top" Margin="20,16,20,16">
                        <TextBlock Text="Hyperion" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Cloud Edition" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    
                    <Button x:Name="InstallBtn" DockPanel.Dock="Bottom"
                            Content="Install Selected (0)"
                            Style="{StaticResource AccentButtonStyle}"
                            Height="40" Margin="16,10,16,18"
                            Click="InstallBtn_Click"/>

                    
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Style="{StaticResource DarkScrollViewer}">
                        <ListBox x:Name="NavList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 SelectionChanged="NavList_SelectionChanged"
                                 Padding="0,4"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavItemStyle}"/>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="MainScroll" Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="24,0,12,0"
                              Style="{StaticResource DarkScrollViewer}">
                    <StackPanel x:Name="ContentPanel" Margin="0,0,0,20">
                        <StackPanel.RenderTransform>
                            <TranslateTransform x:Name="ContentTranslate" Y="0"/>
                        </StackPanel.RenderTransform>
                    </StackPanel>
                </ScrollViewer>

                
                <DockPanel Grid.Row="1" Margin="24,6,24,14">
                    
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusInstalled" Text="" Foreground="#4EC9B0" FontSize="12" Margin="0,0,16,0"/>
                            <TextBlock x:Name="StatusErrors" Text="" Foreground="#F44747" FontSize="12"/>
                        </StackPanel>
                        <Button x:Name="ClearLogBtn" Grid.Column="1" Content="&#xE74D;" Click="ClearLogBtn_Click"
                                Style="{StaticResource TitleBarBtnStyle}" Width="32" Height="28"
                                ToolTip="Очистить лог" Margin="0,0,4,0"/>
                        <Button x:Name="SaveLogBtn" Grid.Column="2" Content="&#xE792;" Click="SaveLogBtn_Click"
                                Style="{StaticResource TitleBarBtnStyle}" Width="32" Height="28"
                                ToolTip="Сохранить лог"/>
                    </Grid>
                    <TextBox x:Name="LogBox"
                             Height="110"
                             Background="{StaticResource LogBgBrush}"
                             Foreground="{StaticResource LogFgBrush}"
                             FontFamily="Consolas" FontSize="12"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="1"
                             BorderBrush="{StaticResource BorderSubtleBrush}"
                             TextWrapping="Wrap"
                             Text="Waiting for selection..."
                             Padding="10,8"
                             CaretBrush="{StaticResource LogFgBrush}"/>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
